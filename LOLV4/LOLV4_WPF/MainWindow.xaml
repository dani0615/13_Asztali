<Window x:Class="LOLV4_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LOLV4_WPF"
        mc:Ignorable="d"
        Title="LOL Hősök" Height="450" Width="800" Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1.3*"/>
            <RowDefinition Height="10*"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
            <ComboBox Name="cbxChampions" Width="100" Margin="10"  />
            <Button x:Name="btnReset" Content="Reset" Width="70" Margin="10" Click="btnReset_Click"/>
            <Button x:Name="btnSave" Content="Mentés" Width="70" Margin="10" Click="btnSave_Click"/>

        </StackPanel>
        <DataGrid x:Name="dgrChampions" Grid.Row="1" Margin="10" ColumnWidth="*"/>

    </Grid>
</Window>

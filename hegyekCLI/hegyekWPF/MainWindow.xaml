<Window x:Class="hegyekWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:hegyekWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="539*"/>
            <ColumnDefinition Width="83*"/>
            <ColumnDefinition Width="178*"/>
        </Grid.ColumnDefinitions>
        <DataGrid x:Name="dgrHegyek" Grid.Row="0" Grid.Column="0" Grid.RowSpan="6" Margin="20,20,20,20" ColumnWidth="*"/>
        <Label Content="Név:" Grid.Row="0" Grid.Column="1" Margin="20,20,20,20" Grid.ColumnSpan="2"/>
        <TextBox x:Name="tbxNev" Grid.Row="0" Grid.Column="2" Height="30" Width="100" HorizontalAlignment="Left"  Grid.ColumnSpan="2"/>
        <Label Content="Hegység" Grid.Column="1" Grid.Row="1" VerticalAlignment="Center" />
        <TextBox x:Name="tbxHegyseg" Grid.Row="1" Grid.Column="2" Height="30" Width="100" HorizontalAlignment="Left" />
        <Label Content="Magasság" Grid.Column="1" Grid.Row="2" VerticalAlignment="Center" />
        <TextBox x:Name="tbxMagassag" Grid.Row="2" Grid.Column="2" Height="30" Width="100" HorizontalAlignment="Left" />
        <Button x:Name="btnHozzad" Content="Hozzáad" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Height="30" Width="100" HorizontalAlignment="Center" Click="btnHozzad_Click"/>
        <Button x:Name="btnMentes" Content="Mentes" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Height="30" Width="100" HorizontalAlignment="Center" Click="btnMentes_Click"/>

    </Grid>
</Window>

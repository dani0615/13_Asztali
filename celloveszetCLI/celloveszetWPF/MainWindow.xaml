<Window x:Class="celloveszetWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:celloveszetWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="2*"/>
            
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="533*"/>
            <ColumnDefinition Width="65*"/>
            <ColumnDefinition Width="202*"/>
        </Grid.ColumnDefinitions>

        <DataGrid x:Name="dgrAdatok" Grid.Column="0" Grid.RowSpan="8" Margin="25,25,25,25" ColumnWidth="*"/>
        
        <Label Content="Név:" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
        <TextBox x:Name="tbxNev" Grid.Row="0" Grid.Column="2" Margin="10"/>

        <Label Content="Lövés1:" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
        <TextBox x:Name="tbxLoves1" Grid.Row="1" Grid.Column="2" Margin="10"/>

        <Label Content="Lövés2:" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
        <TextBox x:Name="tbxLoves2" Grid.Row="2" Grid.Column="2" Margin="10"/>

        <Label Content="Lövés3:" Grid.Row="3" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
        <TextBox x:Name="tbxLoves3" Grid.Row="3" Grid.Column="2" Margin="10"/>

        <Label Content="Lövés4:" Grid.Row="4" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" />
        <TextBox x:Name="tbxLoves4" Grid.Row="4" Grid.Column="2" Margin="10"/>

        <Button Content="Hozzáad" Name="btnHozzaad" Grid.Row="5" Grid.Column="2" Margin="10" Width="60" Click="btnHozzaad_Click" />
        <Button Content="Mentés" Name="btnMentes" Grid.Row="6" Grid.Column="2" Margin="15" Width="60" Click="btnMentes_Click" />
    </Grid>
</Window>

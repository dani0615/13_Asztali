<Window x:Class="VonatokWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VonatokWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        >
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="10">
            <Label Content="Vonalszám"/>
            <ComboBox Height="30" Name="cbxVonalszam" SelectionChanged="cbxVonalszam_SelectionChanged"  />
            <Button Content="Mentés" Margin="10" Name="btnMentes" Click="btnMentes_Click" />

        </StackPanel>
        <TextBlock Grid.Column="1" Margin="10" Name="tbkAdatok" TextWrapping="Wrap"/>


    </Grid>
</Window>

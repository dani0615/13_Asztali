<Window x:Class="NASAWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NASAWPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" Loaded="Window_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="143*"/>
            <ColumnDefinition Width="657*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="55*"/>
            <RowDefinition Height="379*"/>
        </Grid.RowDefinitions>
        <ProgressBar Name="pbTeher" Maximum="77000" Background="#FF1087D6" Foreground="#ffb00693" Grid.Column="0"  Grid.RowSpan="2"  Orientation="Vertical" Width="84"/>
        <Image Grid.Column="0" Grid.RowSpan="2" Source="/rocket.png"   />

        <StackPanel Grid.Column="1" HorizontalAlignment="Left"  Orientation="Horizontal">
            <Button Content="Minden adat" x:Name="btnAdat" Width="80" Margin="10" Click="btnAdat_Click" />
            <Button Content="Statisztika" x:Name="btnStat" Width="70" Margin="10" Click="btnStat_Click"/>
        </StackPanel>
        <Label Content="Statisztika" Name="lblAktualis" Margin="108,291,558,33" Grid.Row="1"  FontWeight="Bold" FontSize="14" Grid.ColumnSpan="2" Background="{x:Null}">
            <Label.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-90.461"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Label.RenderTransform>
        </Label>

        <DataGrid Grid.Column="1" Grid.Row="1" Name="dgrAdat" Margin="10" ColumnWidth="*" SelectionChanged="dgrAdat_SelectionChanged"/>

    </Grid>
</Window>
